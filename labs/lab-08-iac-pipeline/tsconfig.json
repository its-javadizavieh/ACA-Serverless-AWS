{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["es2020"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictFunctionTypes": true,
    "noPropertyAccessFromIndexSignature": false,
    "outDir": "dist",
    "rootDir": "."
  },
  "exclude": ["node_modules", "cdk.out"]
}
